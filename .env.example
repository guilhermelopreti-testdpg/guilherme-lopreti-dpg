# Copie este arquivo para .env e ajuste se precisar:
#   cp .env.example .env
#
# Todas as variáveis têm valor padrão no docker-compose.yml, então o projeto
# sobe sem .env nenhum. O arquivo existe para documentar o que dá para mudar e
# para permitir credenciais reais fora do controle de versão.

POSTGRES_USER=minimonitor
POSTGRES_PASSWORD=minimonitor
POSTGRES_DB=minimonitor

# Porta exposta na máquina host. Troque se você já tiver um Postgres local
# ocupando a 5432.
POSTGRES_PORT=5432